{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "CapyUniverse Docs",
  "colors": {
    "primary": "#7C3AED",
    "light": "#22D3EE",
    "dark": "#A78BFA"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Comece aqui",
        "groups": [
          {
            "group": "Visão geral",
            "pages": [
              "index",
              "quickstart"
            ]
          },
          {
            "group": "Plataforma",
            "pages": [
              "platform/overview",
              "platform/architecture",
              "platform/local-setup",
              "platform/capytool-standard",
              "platform/ai-providers",
              "platform/data-state"
            ]
          }
        ]
      },
      {
        "tab": "Agentes IA",
        "groups": [
          {
            "group": "Sistema de agentes",
            "pages": [
              "agents/overview",
              "agents/infographics",
              "agents/engineering",
              "agents/rendering",
              "agents/documentation"
            ]
          }
        ]
      },
      {
        "tab": "Projetos filhos",
        "groups": [
          {
            "group": "Catálogo do ecossistema",
            "pages": [
              "projects/overview",
              "projects/capyuniverse-core",
              "projects/valerepor",
              "projects/bicou",
              "projects/capymind",
              "projects/buskacep",
              "projects/sentinela-pedreira"
            ]
          }
        ]
      },
      {
        "tab": "Desenvolvimento",
        "groups": [
          {
            "group": "Trabalho técnico",
            "pages": [
              "development/standards",
              "development/contributing",
              "development/deploy"
            ]
          },
          {
            "group": "Governança",
            "pages": [
              "governance/roadmap",
              "governance/security",
              "governance/quality-checklist"
            ]
          }
        ]
      },
      {
        "tab": "Referência",
        "groups": [
          {
            "group": "Padrões e glossário",
            "pages": [
              "reference/glossary",
              "reference/project-template",
              "reference/agent-template"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "CapyUniverse",
          "href": "https://github.com/faelscarpato/capyuniverse",
          "icon": "sparkles"
        },
        {
          "anchor": "Portfólio",
          "href": "https://faelscarpato.github.io/",
          "icon": "globe"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/faelscarpato/capyuniverse"
      },
      {
        "label": "Demo",
        "href": "https://faelscarpato.github.io/capyuniverse/"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Abrir Universo",
      "href": "https://faelscarpato.github.io/capyuniverse/"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/faelscarpato"
    }
  }
}
